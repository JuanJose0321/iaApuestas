# ============================================================
# Copia este archivo como .env y rellena tus valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# API-Football (api-sports.io) — registra en https://www.api-football.com/
# Free tier: 100 requests/día
API_FOOTBALL_KEY=TU_KEY_AQUI
API_FOOTBALL_HOST=v3.football.api-sports.io

# Sportmonks (sportmonks.com) — OPCIONAL, solo fallback si api-football falla
# Free trial disponible en https://www.sportmonks.com/
SPORTMONKS_TOKEN=

# Groq (LLM narrador) — registra en https://console.groq.com/
# Gratis con límites generosos
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Flask
FLASK_DEBUG=0
FLASK_PORT=5000

# Bankroll y Kelly
BANKROLL_INICIAL=1000
KELLY_FRACTION=0.25
MIN_EV=0.05

# Caché de API en horas
CACHE_TTL_HORAS=12
